# Solana RPC + cluster (devnet recommended while testing)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_CLUSTER=devnet

# Public treasury address — must receive create + buy payments
FEE_RECIPIENT=YourSolanaPublicKeyHere

# Base58 secret key of the same treasury wallet (used to pay out sells)
# NEVER commit a mainnet key. Fund this wallet with SOL for sell payouts.
PLATFORM_WALLET_SECRET=YourBase58SecretKeyHere

ADMIN_PASSWORD=your-secure-password-here
